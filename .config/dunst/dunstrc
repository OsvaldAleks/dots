[global]
    icon_theme = Papirus-dark
    monitor = 0
    width = (350, 350)
    height = (50,1000)
    origin = top-center
    offset = 20x20
    notification_limit = 5
    progress_bar = true
    progress_bar_height = 15
    progress_bar_frame_width = 0
    progress_bar_min_width = 350
    progress_bar_max_width = 350
    progress_bar_corner_radius = 0
    icon_corner_radius = 0
    indicate_hidden = true
    padding = 10
    horizontal_padding = 10
    text_icon_padding = 10
    frame_width = 1
    gap_size = 5
    sort = urgency_descending
    idle_threshold = 120
    font = "DejaVu Sans"
    line_height = 10
    format = "<sub>%a</sub>\n<b>%s</b>\n%b\n"
    alignment = left
    vertical_alignment = center
    word_wrap = yes
    ellipsize = none
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = true
    enable_recursive_icon_lookup = true
    icon_position = left
    min_icon_size = 80
    max_icon_size = 80
    sticky_history = yes
    history_length = 50
    dmenu = fuzzel
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 3
    ignore_dbusclose = false
    force_xwayland = false
    force_xinerama = false
    mouse_left_click = do_action, close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all
    background = "#1D1C1A80"
    separator_color = "#00000000"
    frame_color = "#89847d80"

[experimental]
    per_monitor_dpi = false

[urgency_low]
    foreground = "#F1E4D0"
    highlight = "#F1E4D0"
    timeout = 5

[urgency_normal]
    foreground = "#F1E4D0"
    highlight = "#daee76"
    timeout = 5

[urgency_critical]
    foreground = "#F2412A"
    highlight = "#F2412A"
    timeout = 0

[ignore_status_updates]
    appname = "status"
    foreground = "#EAD91F"
    highlight = "#b3640b"
    frame_color = "#b3640b"
    timeout = 0
    format = "<b>%s</b>\n%b\n"
    history_ignore = true
